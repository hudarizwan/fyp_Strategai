# StrategAI backend environment template

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Scraping / ingestion
APIFY_API_TOKEN=your_apify_token
APIFY_API_KEY=your_apify_key
SCRAPERAPI_KEY=your_scraperapi_key

# Ollama
OLLAMA_BASE_URL=https://q7fn9rrgympjqn-11434.proxy.runpod.net
OLLAMA_MODEL=llama3.1:8b

# Runtime
PORT=8001
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
HEALTHCHECK_TIMEOUT_SECONDS=3
MARKETING_REQUEST_TIMEOUT_SECONDS=45
MARKETING_INLINE_TIMEOUT_SECONDS=20
RUN_INLINE_MARKETING=false

